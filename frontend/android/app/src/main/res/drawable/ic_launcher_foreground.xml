<?xml version="1.0" encoding="utf-8"?>
<!--
    Shadow Catcher
    App Icon Foreground - Shield with Eye Symbol
    Used by all adaptive icon mipmaps
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer glow circle -->
    <path
        android:pathData="M54,54m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0"
        android:fillColor="#1A1A2E"
        android:strokeColor="#00D4FF"
        android:strokeWidth="1.5"/>

    <!-- Shield body -->
    <path
        android:pathData="M54,18
                          L78,28
                          L78,52
                          C78,66 66,76 54,82
                          C42,76 30,66 30,52
                          L30,28
                          Z"
        android:fillColor="#0F3460"
        android:strokeColor="#00D4FF"
        android:strokeWidth="2"/>

    <!-- Shield inner highlight -->
    <path
        android:pathData="M54,24
                          L74,33
                          L74,52
                          C74,63 63,72 54,77
                          C45,72 34,63 34,52
                          L34,33
                          Z"
        android:fillColor="#16213E"/>

    <!-- Eye outer -->
    <ellipse
        android:centerX="54"
        android:centerY="50"
        android:radiusX="12"
        android:radiusY="8"
        android:fillColor="#00D4FF"
        android:fillAlpha="200"/>

    <!-- Eye pupil -->
    <path
        android:pathData="M54,50m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0"
        android:fillColor="#1A1A2E"/>

    <!-- Eye shine -->
    <path
        android:pathData="M56,47m-1.5,0a1.5,1.5 0,1 1,3 0a1.5,1.5 0,1 1,-3 0"
        android:fillColor="#FFFFFF"/>

    <!-- Shield check mark at bottom -->
    <path
        android:pathData="M46,62 L51,68 L62,56"
        android:strokeColor="#00FF88"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

</vector>
